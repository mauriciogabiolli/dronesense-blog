---
import BaseLayout from './BaseLayout.astro';
import BlogNavbar from '../components/BlogNavbar.astro';
import BlogFooter from '../components/BlogFooter.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: string;
  imageAlt?: string;
  category?: string;
  tags?: string[];
  readingTime?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'Equipe DroneSense',
  image,
  imageAlt,
  category,
  tags = [],
  readingTime = 5,
} = Astro.props;

const base = import.meta.env.BASE_URL;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout {title} {description} {pubDate} {updatedDate} {author} {image} {imageAlt} {tags} isPost={true}>
  <BlogNavbar />

  <main>
    <!-- Hero do post -->
    <div class="relative">
      {image ? (
        <div class="relative h-72 md:h-[440px] overflow-hidden bg-slate-100">
          <img
            src={image}
            alt={imageAlt || title}
            class="w-full h-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

          <!-- Post header over image -->
          <div class="absolute bottom-0 left-0 right-0 px-6 pb-10">
            <div class="max-w-[720px] mx-auto">
              {category && (
                <span class="inline-block bg-agro text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-4">
                  {category}
                </span>
              )}
              <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight">
                {title}
              </h1>
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-slate-950 pt-16 pb-12 px-6">
          <div class="max-w-[720px] mx-auto">
            {category && (
              <span class="inline-block border border-agro/40 bg-agro/10 text-agro text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
                {category}
              </span>
            )}
            <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight animate-fade-up">
              {title}
            </h1>
          </div>
        </div>
      )}
    </div>

    <!-- Post meta + content -->
    <div class="max-w-[720px] mx-auto px-6">

      <!-- Meta bar -->
      <div class="flex flex-wrap items-center gap-4 py-6 border-b border-slate-100 text-sm text-slate-400 mb-10">
        <!-- Breadcrumb inline -->
        <nav class="flex items-center gap-1.5 text-xs">
          <a href="/" class="hover:text-agro transition-colors">Início</a>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <a href={base} class="hover:text-agro transition-colors">Blog</a>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-slate-500 truncate max-w-[180px]">{title}</span>
        </nav>

        <div class="flex-1 hidden sm:block"></div>

        <!-- Author + date -->
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 rounded-full bg-agro flex items-center justify-center text-white text-[10px] font-bold">
            DS
          </div>
          <div>
            <span class="text-slate-700 font-medium text-xs block">{author}</span>
            <time datetime={pubDate.toISOString()} class="text-[11px]">{formattedDate}</time>
          </div>
        </div>

        <span class="text-slate-200">·</span>

        <span class="flex items-center gap-1.5 text-xs">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          ~{readingTime} min de leitura
        </span>
      </div>

      <!-- Description / lead -->
      <p class="text-xl text-slate-500 leading-relaxed mb-10 font-serif italic">
        {description}
      </p>

      <!-- Article body -->
      <article class="article-prose mb-16">
        <slot />
      </article>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pb-10 border-b border-slate-100">
          {tags.map(tag => (
            <span class="text-xs font-medium text-slate-500 bg-slate-100 hover:bg-agro-light hover:text-agro transition-colors px-3 py-1.5 rounded-full cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      )}

      {updatedDate && (
        <p class="text-xs text-slate-300 mt-4 mb-8">
          Última atualização: {updatedDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      )}

      <!-- CTA box -->
      <div class="relative overflow-hidden rounded-2xl bg-slate-950 p-8 md:p-10 my-12 text-center">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-agro to-transparent opacity-60"></div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-agro/70 mb-4 block">DroneSense</span>
        <h3 class="font-serif text-2xl md:text-3xl font-bold text-white mb-3">
          Pronto para modernizar sua operação?
        </h3>
        <p class="text-slate-400 mb-8 max-w-md mx-auto text-sm leading-relaxed">
          Fale com nossos especialistas e descubra o drone agrícola ideal para a sua cultura e tamanho de área.
        </p>
        <a
          href="https://api.whatsapp.com/send?phone=5516997347159&text=Ol%C3%A1%2C+vi+o+blog+da+DroneSense+e+tenho+interesse!"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-agro hover:bg-agro-dark text-white font-semibold px-8 py-3.5 rounded-full transition-all hover:scale-105 text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Falar com Especialista
        </a>
      </div>
    </div>
  </main>

  <BlogFooter />
</BaseLayout>
