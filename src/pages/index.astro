---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogNavbar from '../components/BlogNavbar.astro';
import BlogFooter from '../components/BlogFooter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.filter(p => p.data.featured).slice(0, 1)[0];
const recent = posts.filter(p => !p.data.featured || p.id !== featured?.id).slice(0, 9);
const base = import.meta.env.BASE_URL;
const postUrl = (id: string) => `${base}/${id}`.replace('//', '/');

function readingTime(description: string) {
  const words = description.split(' ').length;
  return Math.max(3, Math.ceil(words / 200));
}
---

<BaseLayout
  title="Blog DroneSense — Tecnologia e Drones Agrícolas"
  description="Artigos técnicos sobre drones agrícolas, automação rural, ROI, legislação ANAC e as melhores práticas do setor."
>
  <BlogNavbar />

  <main>
    <!-- Hero section -->
    <section class="relative overflow-hidden bg-slate-950 py-24 px-6">
      <!-- Subtle grid texture -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-rule='evenodd'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/svg%3E\")"></div>
      <!-- Green accent line at bottom -->
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-agro to-transparent opacity-60"></div>

      <div class="relative max-w-3xl mx-auto text-center">
        <div class="animate-fade-up inline-flex items-center gap-2 border border-agro/30 bg-agro/10 text-agro text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-8">
          <span class="w-1.5 h-1.5 bg-agro rounded-full"></span>
          Blog DroneSense
        </div>
        <h1 class="animate-fade-up-delay-1 font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-6">
          Inteligência para<br /><span class="text-agro">quem trabalha</span><br />com o campo
        </h1>
        <p class="animate-fade-up-delay-2 text-slate-400 text-lg md:text-xl leading-relaxed max-w-xl mx-auto">
          Conteúdo técnico sobre drones agrícolas, automação rural, ROI e as melhores práticas do setor.
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 py-20">

      <!-- Post em destaque -->
      {featured && (
        <section class="mb-20 animate-fade-up">
          <div class="flex items-center gap-3 mb-8">
            <span class="text-[10px] font-bold uppercase tracking-widest text-agro">Em Destaque</span>
            <div class="flex-1 h-px bg-slate-100"></div>
          </div>

          <a href={postUrl(featured.id)} class="group block">
            <div class="grid md:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-slate-100 card-hover bg-white">
              <!-- Image -->
              <div class="relative h-72 md:h-full bg-slate-100 overflow-hidden">
                {featured.data.image ? (
                  <img
                    src={featured.data.image}
                    alt={featured.data.imageAlt || featured.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-agro-dark to-agro flex items-center justify-center">
                    <span class="text-white/20 text-8xl font-serif font-bold">DS</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-r from-black/30 to-transparent"></div>
                <span class="absolute top-5 left-5 bg-white text-agro text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm">
                  {featured.data.category}
                </span>
              </div>

              <!-- Content -->
              <div class="p-8 md:p-10 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-5 text-xs text-slate-400 font-medium">
                  <time datetime={featured.data.pubDate.toISOString()}>
                    {featured.data.pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <span>·</span>
                  <span>Leitura de ~5 min</span>
                </div>
                <h2 class="font-serif text-2xl md:text-3xl font-bold text-slate-900 leading-snug mb-4 group-hover:text-agro transition-colors">
                  {featured.data.title}
                </h2>
                <p class="text-slate-500 leading-relaxed mb-6 text-sm md:text-base">
                  {featured.data.description}
                </p>
                <span class="flex items-center gap-2 text-agro font-semibold text-sm group-hover:gap-3 transition-all">
                  Ler artigo completo
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </section>
      )}

      <!-- Grid de posts recentes -->
      {recent.length > 0 && (
        <section>
          <div class="flex items-center gap-3 mb-10">
            <span class="text-[10px] font-bold uppercase tracking-widest text-agro">Artigos Recentes</span>
            <div class="flex-1 h-px bg-slate-100"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {recent.map((post, i) => (
              <a
                href={postUrl(post.id)}
                class={`group flex flex-col bg-white rounded-2xl border border-slate-100 overflow-hidden card-hover animate-fade-up-delay-${Math.min(i + 1, 4)}`}
              >
                <!-- Image -->
                <div class="relative h-52 bg-slate-50 overflow-hidden">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
                      <span class="text-slate-300 text-4xl font-serif font-bold">DS</span>
                    </div>
                  )}
                </div>

                <!-- Content -->
                <div class="flex flex-col flex-1 p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-[10px] font-bold uppercase tracking-widest text-agro bg-agro-light px-2.5 py-1 rounded-full">
                      {post.data.category}
                    </span>
                  </div>
                  <h3 class="font-serif font-semibold text-slate-900 text-lg leading-snug mb-2 group-hover:text-agro transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 flex-1">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between mt-5 pt-4 border-t border-slate-50">
                    <time class="text-xs text-slate-300">
                      {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
                    </time>
                    <span class="text-xs font-semibold text-agro group-hover:gap-2 flex items-center gap-1 transition-all">
                      Ler
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {posts.length === 0 && (
        <div class="text-center py-32">
          <p class="font-serif text-3xl font-bold text-slate-200 mb-3">Em breve</p>
          <p class="text-slate-400">Novos artigos chegando em breve.</p>
        </div>
      )}
    </div>

    <!-- Newsletter / CTA strip -->
    <section class="border-t border-slate-100 bg-slate-50 py-16 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-agro mb-4">Quer saber mais?</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3">Fale com nossos especialistas</h2>
        <p class="text-slate-500 mb-8">Nossa equipe está pronta para apresentar a solução ideal para a sua operação.</p>
        <a
          href="https://api.whatsapp.com/send?phone=5516997347159&text=Ol%C3%A1%2C+vi+o+blog+da+DroneSense+e+tenho+interesse!"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-agro hover:bg-agro-dark text-white font-semibold px-8 py-3.5 rounded-full transition-all hover:scale-105 shadow-sm shadow-agro/20"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>
    </section>
  </main>

  <BlogFooter />
</BaseLayout>
