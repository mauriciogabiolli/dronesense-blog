---
const base = import.meta.env.BASE_URL;
---

<header id="blog-nav" class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 transition-shadow duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">

    <!-- Left -->
    <div class="flex items-center gap-3 min-w-0">

      <!-- Voltar -->
      <a href="/" class="flex items-center gap-1 text-slate-400 hover:text-agro transition-colors text-sm font-medium shrink-0 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden md:inline">Início</span>
      </a>

      <div class="w-px h-5 bg-slate-200 shrink-0"></div>

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="DroneSense">
        <img src="/img/logo-dronesense.webp" alt="DroneSense" class="h-7 w-auto object-contain" />
        <div class="w-px h-5 bg-slate-200 hidden sm:block"></div>
        <img src="/header_partners.png" alt="Revenda DJI Agriculture" class="h-4 w-auto object-contain mix-blend-multiply opacity-80 hidden sm:block" />
      </a>

      <!-- Blog tag — desktop only -->
      <div class="w-px h-5 bg-slate-200 hidden lg:block shrink-0"></div>
      <a href={base} class="hidden lg:flex items-center gap-1.5 text-agro font-semibold text-sm hover:text-agro-dark transition-colors shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        Blog
      </a>
    </div>

    <!-- Right: CTA -->
    <a
      href="https://api.whatsapp.com/send?phone=5516997347159&text=Ol%C3%A1%2C+tenho+interesse+nos+drones+agr%C3%ADcolas+DroneSense%21"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-4 py-2 bg-agro hover:bg-agro-dark text-white rounded-full font-semibold text-sm transition-all hover:scale-105 shadow-sm whitespace-nowrap shrink-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
      </svg>
      <span class="hidden sm:inline">Falar no WhatsApp</span>
      <span class="sm:hidden">WhatsApp</span>
    </a>

  </div>
</header>

<script>
  const nav = document.getElementById('blog-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('shadow-sm', window.scrollY > 10);
  }, { passive: true });
</script>
