---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-500 mt-0">
  <!-- Top accent -->
  <div class="h-px bg-gradient-to-r from-transparent via-agro/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-slate-800/60">

      <!-- Brand -->
      <div>
        <img src="/img/logo-dronesense.webp" alt="DroneSense" class="h-8 w-auto brightness-0 invert opacity-60 mb-4" />
        <p class="text-sm text-slate-500 leading-relaxed max-w-xs">
          Tecnologia agrícola de precisão. Revendedor oficial DJI Agriculture no interior de São Paulo.
        </p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-4">Navegação</p>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-sm hover:text-white transition-colors">Site Principal</a></li>
          <li><a href={base} class="text-sm hover:text-white transition-colors">Blog</a></li>
          <li><a href="/drones-agricolas/dji-agras-t25p" class="text-sm hover:text-white transition-colors">DJI Agras T25P</a></li>
          <li><a href="/drones-agricolas/dji-agras-t70p" class="text-sm hover:text-white transition-colors">DJI Agras T70P</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-4">Contato</p>
        <ul class="space-y-2.5">
          <li>
            <a
              href="https://api.whatsapp.com/send?phone=5516997347159"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm hover:text-white transition-colors flex items-center gap-2"
            >
              <svg class="w-3.5 h-3.5 text-agro" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              +55 (16) 99734-7159
            </a>
          </li>
          <li>
            <a href="mailto:contato@dronesense.com.br" class="text-sm hover:text-white transition-colors">
              contato@dronesense.com.br
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-3 pt-6 text-xs text-slate-700">
      <p>© {year} DroneSense. Todos os direitos reservados.</p>
      <div class="flex items-center gap-2">
        <img src="/header_partners.png" alt="DJI Agriculture" class="h-4 w-auto brightness-0 invert opacity-20 mix-blend-screen" />
      </div>
    </div>
  </div>
</footer>
