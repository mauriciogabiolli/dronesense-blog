---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400">

  <!-- Linha de acento verde no topo -->
  <div class="h-px bg-gradient-to-r from-transparent via-agro/50 to-transparent"></div>

  <!-- CTA strip -->
  <div class="border-b border-slate-800/60">
    <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-agro mb-1">Pronto para modernizar sua operação?</p>
        <p class="text-white text-xl font-semibold leading-snug">Fale com nossa equipe de especialistas.</p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <a
          href="https://api.whatsapp.com/send?phone=5516997347159&text=Ol%C3%A1%2C+tenho+interesse+nos+drones+agr%C3%ADcolas+DroneSense!"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 bg-agro hover:bg-agro-dark text-white font-semibold px-6 py-3 rounded-full text-sm transition-all hover:scale-105 shadow-lg shadow-agro/20 whitespace-nowrap"
        >
          <!-- WhatsApp icon -->
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Falar no WhatsApp
        </a>
        <a
          href="mailto:contato@dronesense.com.br"
          class="flex items-center gap-2 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white font-semibold px-6 py-3 rounded-full text-sm transition-all whitespace-nowrap"
        >
          <!-- Email icon -->
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          E-mail
        </a>
      </div>
    </div>
  </div>

  <!-- Main footer grid -->
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Coluna 1: Marca -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/">
          <img
            src="/img/logo-dronesense.webp"
            alt="DroneSense"
            class="h-9 w-auto object-contain brightness-0 invert opacity-80 mb-5"
          />
        </a>
        <p class="text-sm text-slate-500 leading-relaxed mb-6">
          Revendedor oficial DJI Agriculture e xMobots no interior de São Paulo. Tecnologia de precisão para a agricultura moderna.
        </p>
        <!-- Badges -->
        <div class="flex items-center gap-3">
          <img
            src="/header_partners.png"
            alt="Revenda Oficial DJI Agriculture"
            class="h-6 w-auto object-contain brightness-0 invert opacity-30"
          />
        </div>
      </div>

      <!-- Coluna 2: Produtos -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-5">Produtos</p>
        <ul class="space-y-3">
          <li>
            <a href="/drones-agricolas/dji-agras-t25p" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              DJI Agras T25P
            </a>
          </li>
          <li>
            <a href="/drones-agricolas/dji-agras-t70p" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              DJI Agras T70P
            </a>
          </li>
          <li>
            <a href="/#produtos" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              Ver todos os drones
            </a>
          </li>
          <li>
            <a href="/#cursos" class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              Cursos de Piloto
            </a>
          </li>
        </ul>
      </div>

      <!-- Coluna 3: Blog -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-5">Blog</p>
        <ul class="space-y-3">
          <li>
            <a href={base} class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              Todos os artigos
            </a>
          </li>
          <li>
            <a href={`${base}/como-calcular-roi-drone-agricola`} class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              ROI de Drones Agrícolas
            </a>
          </li>
          <li>
            <a href={`${base}/dji-agras-t25p-vs-t70p`} class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              T25P vs T70P
            </a>
          </li>
          <li>
            <a href={`${base}/legislacao-drone-agricola-anac-2025`} class="text-sm text-slate-400 hover:text-white transition-colors flex items-center gap-2 group">
              <span class="w-1 h-1 rounded-full bg-agro/50 group-hover:bg-agro transition-colors shrink-0"></span>
              Legislação ANAC 2025
            </a>
          </li>
        </ul>
      </div>

      <!-- Coluna 4: Contato -->
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-5">Contato</p>
        <ul class="space-y-4">
          <li>
            <a
              href="https://api.whatsapp.com/send?phone=5516997347159"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start gap-3 hover:text-white transition-colors"
            >
              <div class="w-8 h-8 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 group-hover:border-agro/40 transition-colors mt-0.5">
                <svg class="w-4 h-4 text-agro" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.525 5.845L.057 23.743a.5.5 0 00.612.612l5.898-1.468A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.89 0-3.665-.523-5.18-1.432l-.371-.222-3.843.957.974-3.747-.241-.386A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-600 mb-0.5">WhatsApp</p>
                <p class="text-sm text-slate-300">(16) 99734-7159</p>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:contato@dronesense.com.br" class="group flex items-start gap-3 hover:text-white transition-colors">
              <div class="w-8 h-8 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 group-hover:border-agro/40 transition-colors mt-0.5">
                <svg class="w-4 h-4 text-agro" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-slate-600 mb-0.5">E-mail</p>
                <p class="text-sm text-slate-300">contato@dronesense.com.br</p>
              </div>
            </a>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-agro" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-600 mb-0.5">Localização</p>
              <p class="text-sm text-slate-300 leading-snug">Interior de São Paulo, Brasil</p>
            </div>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-800/60">
    <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
      <p>© {year} DroneSense Tecnologia Agrícola. Todos os direitos reservados.</p>
      <div class="flex items-center gap-5">
        <a href="/" class="hover:text-slate-400 transition-colors">Site Principal</a>
        <a href={base} class="hover:text-slate-400 transition-colors">Blog</a>
        <span class="text-slate-800">·</span>
        <span>CNPJ 25.330.277/0001-03</span>
      </div>
    </div>
  </div>

</footer>
